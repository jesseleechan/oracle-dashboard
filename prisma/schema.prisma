// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Log {
  id            String    @id @default(cuid())
  date          String
  universalDay  Int
  transitAspect String
  tarotCards    String
  scene         String
  flowState     String?
  isRealized    Boolean   @default(false)
  sceneHistory  String?  
  reflection    String?
  revisedScene  String?
  revisedAt     DateTime?
  isImpressed   Boolean   @default(false)
  assumptionText String?
  feelingRating  Int?
  mappedSephira  String?
  mappedPath     Int?
  sensoryScript String?
  createdAt     DateTime  @default(now())
}

model JournalEntry {
  id              String    @id @default(cuid())
  type            String    // "dream" or "synchronicity"
  content         String
  date            String
  geminiAnalysis  String?
  linkedToSceneId String?
  createdAt       DateTime  @default(now())
}

model SavedPattern {
  id        String   @id @default(cuid())
  date      String
  timeframe String   // "30" or "90"
  patterns  String   // JSON stringified Gemini response
  createdAt DateTime @default(now())
}
