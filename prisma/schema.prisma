// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Log {
  id            String    @id @default(cuid())
  date          String
  universalDay  Int
  transitAspect String
  tarotCards    String
  scene         String
  flowState     String?
  isRealized    Boolean   @default(false)
  sceneHistory  String?  
  reflection    String?
  revisedScene  String?
  revisedAt     DateTime?
  isImpressed   Boolean   @default(false)
  createdAt     DateTime  @default(now())
}
